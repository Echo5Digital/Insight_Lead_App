MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=insightlead
IL_API_KEY_PEPPER=replace-with-a-long-random-string
JWT_SECRET=replace-with-another-long-random-string
SETUP_DONE=false
PORT=3001

# HIPAA: PHI field-level encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-char-hex-strings
SEARCH_HMAC_KEY=replace-with-another-64-char-hex-strings
# Only needed during key rotation — leave blank otherwised
# Only needed during key rotation — leave blank otherwise

ENCRYPTION_KEY_OLD=

# Comma-separated list of emails whose activity is NEVER stored in audit_logs
# Example: AUDIT_EXCLUDE_EMAILS=sony@example.com,boss@example.com
AUDIT_EXCLUDE_EMAILS=
